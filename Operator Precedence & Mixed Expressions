#include <iostream>
using namespace std;

int main()
{
    cout << "10 + 2 * 5 = " << 10 + 2 * 5 << endl;

    cout << "(10 + 2) * 5 = " << (10 + 2) * 5 << endl;

    cout << "20 / 4 + 3 * 2 = " << 20 / 4 + 3 * 2 << endl;

    cout << "20 / (4 + 3) * 2 = " << 20 / (4 + 3) * 2 << endl;

    float result = 5 + 2.5 * 4;

    cout << "Mixed Expression = " << result << endl;

    return 0;
}
