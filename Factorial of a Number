#include <iostream>
using namespace std;

int main()
{
    int n, i = 1;
    long long fact = 1;

    cout << "Enter a number: ";
    cin >> n;

    if (n < 0)
    {
        cout << "Factorial not possible.";
    }
    else
    {
        while (i <= n)
        {
            fact *= i;
            i++;
        }

        cout << "Factorial = " << fact;
    }

    return 0;
}
